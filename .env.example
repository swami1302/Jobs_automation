# Copy this file to ".env" and fill in your real keys.
# .env is gitignored — never commit real keys.

# ============================================================
# LLM PROVIDERS (free, with automatic fallback)
# ============================================================
# Tried left-to-right. First one with a key that responds wins.
# Transient errors (503/429/timeout) auto-retry before falling through.
LLM_PROVIDER_ORDER=nvidia,gemini

# --- NVIDIA (free: https://build.nvidia.com) — primary ---
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Gemini (free: https://aistudio.google.com) — fallback ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# ADDING A NEW MODEL LATER  (no code changes needed)
# ------------------------------------------------------------
# Any OpenAI-compatible provider works out of the box. Two cases:
#
# 1) Known provider (groq, openrouter, openai, deepseek, together, anthropic):
#    just add its key and put its name in LLM_PROVIDER_ORDER. e.g.:
#       LLM_PROVIDER_ORDER=nvidia,gemini,groq
#       GROQ_API_KEY=gsk_...
#    (override its model with GROQ_MODEL=... if you want a different one)
#
# 2) Brand-new OpenAI-compatible provider not built in:
#       LLM_PROVIDER_ORDER=nvidia,gemini,myllm
#       MYLLM_API_KEY=...
#       MYLLM_BASE_URL=https://api.myllm.com/v1
#       MYLLM_MODEL=some-model
#
# Examples (uncomment + add keys to enable):
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=

# ============================================================
# OTHER SERVICES (needed in later milestones)
# ============================================================
# Apify token (https://console.apify.com/account/integrations) — M2 scraping
APIFY_TOKEN=
# M2 scraper tuning (optional — sensible defaults if omitted)
# APIFY_ACTOR=curious_coder/linkedin-jobs-scraper
# JOB_SOURCE=linkedin
# JOBS_PER_RUN=20
# MAX_TITLES=4
# SCRAPE_COMPANY=true

# Telegram bot token (from @BotFather) — M4 swipe bot
TELEGRAM_BOT_TOKEN=

# Database — leave blank to use local SQLite (data/db/jobs.db).
# Set to your Neon Postgres URL to use the cloud DB instead:
#   postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Apollo.io API key — OPTIONAL, M5 contact enrichment (find hiring emails)
# APOLLO_API_KEY=
