# Copy this file to ".env" and fill in your real keys.
# .env is gitignored — never commit real keys.

# ============================================================
# LLM PROVIDERS (free, with automatic fallback)
# ============================================================
# Tried left-to-right. First one with a key that responds wins.
# Transient errors (503/429/timeout) auto-retry before falling through.
LLM_PROVIDER_ORDER=nvidia,gemini

# --- NVIDIA (free: https://build.nvidia.com) — primary ---
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Gemini (free: https://aistudio.google.com) — fallback ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ------------------------------------------------------------
# ADDING A NEW MODEL LATER  (no code changes needed)
# ------------------------------------------------------------
# Any OpenAI-compatible provider works out of the box. Two cases:
#
# 1) Known provider (groq, openrouter, openai, deepseek, together, anthropic):
#    just add its key and put its name in LLM_PROVIDER_ORDER. e.g.:
#       LLM_PROVIDER_ORDER=nvidia,gemini,groq
#       GROQ_API_KEY=gsk_...
#    (override its model with GROQ_MODEL=... if you want a different one)
#
# 2) Brand-new OpenAI-compatible provider not built in:
#       LLM_PROVIDER_ORDER=nvidia,gemini,myllm
#       MYLLM_API_KEY=...
#       MYLLM_BASE_URL=https://api.myllm.com/v1
#       MYLLM_MODEL=some-model
#
# Examples (uncomment + add keys to enable):
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# ANTHROPIC_API_KEY=

# ============================================================
# OTHER SERVICES (needed in later milestones)
# ============================================================
# Apify token (https://console.apify.com/account/integrations) — M2 scraping
APIFY_TOKEN=
# M2 scraper tuning (optional — sensible defaults if omitted)
# JOB_SOURCES=linkedin,indeed,naukri  (which portals to scrape)
# APIFY_ACTOR=curious_coder/linkedin-jobs-scraper
# JOB_SOURCE=linkedin
# JOBS_PER_RUN=20
# MAX_TITLES=4
# SCRAPE_COMPANY=true

# Telegram bot token (from @BotFather) — M4 swipe bot
TELEGRAM_BOT_TOKEN=
# Only show jobs scoring >= this in the bot (default 50)
# MIN_MATCH_SCORE=50
# Lock the bot to your Telegram account (see your id via /start). Optional.
# TELEGRAM_USER_ID=

# Database — leave blank to use local SQLite (data/db/jobs.db).
# Set to your Neon Postgres URL to use the cloud DB instead:
#   postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Apollo.io API key — OPTIONAL, M5 contact enrichment (find hiring emails)
# APOLLO_API_KEY=

# Hunter.io API key — M5 contact/email enrichment (free tier ~25/mo)
HUNTER_API_KEY=

# Gmail send (M6) — App Password, NOT your normal password.
# Used for local sending via SMTP. NOTE: most free PaaS (incl. Render free tier)
# BLOCK outbound SMTP ports 25/465/587, so SMTP won't work on a free deploy —
# use Brevo below for hosted sending.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Brevo HTTP email (https://app.brevo.com) — sends over port 443, so it works
# where SMTP is blocked. If BREVO_API_KEY is set it takes priority over Gmail SMTP.
# 1) sign up (free ~300 emails/day), 2) verify your sender address under
#    Senders & IPs, 3) create an API key under SMTP & API → API Keys.
# BREVO_API_KEY=
# From address for sent mail (must be a Brevo-verified sender). Defaults to
# GMAIL_ADDRESS if left blank.
# SENDER_EMAIL=

# Public resume link shown in the LinkedIn-message signature (e.g. a Google
# Drive share link set to "Anyone with the link"). Optional — the line is
# omitted if blank. The email still attaches the local PDF regardless.
RESUME_URL=

# ============================================================
# DEPLOY (M8 — scripts/panel.py on Render free tier)
# ============================================================
# Auto-start the Telegram bot when the panel boots (Render has no UI to click
# ▶️ Start Bot). A watchdog respawns it if it crashes. Leave blank locally so
# you don't double-run the bot. Set to "true" on Render.
# AUTOSTART_BOT=

# Run scrape+match automatically once a day (M7b). Off unless set true.
# DAILY_CRON=
# CRON_HOUR=6          # hour (24h) in CRON_TZ
# CRON_MINUTE=0
# CRON_TZ=Asia/Kolkata

# Render injects $PORT automatically; PANEL_PORT is the local fallback (8000).
# PANEL_PORT=8000
